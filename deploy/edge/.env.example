EDGE_RUNTIME_IMAGE=cdn-edge-runtime:local
EDGE_BIND_ADDRESS=0.0.0.0
EDGE_HTTP_PORT=8080

# Public HTTPS URL of the control-plane edge gateway.
EDGE_CONTROL_PLANE_URL=https://edge-control.example.com
EDGE_GATEWAY_CA_FILE=./secrets/edge-gateway-ca.crt
EDGE_BOOTSTRAP_TOKEN_FILE=./secrets/edge-bootstrap-token

EDGE_ARTIFACT_MAX_BYTES=67108864
EDGE_COMMAND_TIMEOUT=30s
EDGE_HEALTH_TIMEOUT=5s
EDGE_JITTER_FRACTION=0.2
EDGE_MAX_BACKOFF=5m
EDGE_POLL_INTERVAL=30s
EDGE_RELEASE_RETENTION=5

# Node telemetry. CPU, memory, disk, bandwidth and requests-per-second are
# collected by default (from /proc, statfs and the local OpenResty stub_status
# endpoint). Override the stub_status endpoint only if you relocated it:
# EDGE_STATUS_URL=http://127.0.0.1:8080/nginx_status
#
# Error rate is derived from the active release's JSON access log on the shared
# volume (default: <EDGE_DATA_DIR>/current/logs/access.log), which OpenResty
# writes via the signed edge config, so it is reported out of the box. Set to
# "off" to disable, or point at a custom absolute path.
# EDGE_ACCESS_LOG_FILE=off

# ---------------------------------------------------------------------------
# Observability profile (optional)
#
# Vector (log shipping) and nginx-prometheus-exporter (metrics) are gated behind
# the Compose "observability" profile. The default `docker compose up -d` does
# NOT start them. Enable them explicitly:
#
#   docker compose --profile observability up -d
#
# Host interface for the published metrics ports (nginx-prometheus-exporter
# :9113 and Vector :9598). Keep this on loopback and let a local Prometheus /
# scraper reach it; never expose cache/status/metrics endpoints to the Internet.
EDGE_METRICS_BIND_ADDRESS=127.0.0.1

# Pin the observability images (override to upgrade/downgrade). These tags are
# the latest stable releases verified at authoring time; keep them pinned rather
# than tracking :latest so upgrades are deliberate.
EDGE_VECTOR_IMAGE=timberio/vector:0.56.0-alpine
EDGE_NGINX_EXPORTER_IMAGE=nginx/nginx-prometheus-exporter:1.5.1

# Wiring caveat 1 (metrics): OpenResty's /nginx_status is loopback-only
# (allow 127.0.0.1; allow ::1; deny all) in both the baked and the signed
# release config, so a scrape from the exporter container over the `edge`
# bridge network returns HTTP 403. To collect NGINX metrics, either extend the
# stub_status allow-list to the compose bridge subnet in the OpenResty config,
# or run the exporter as an OpenResty netns sidecar (network_mode:
# service:openresty) scraping http://127.0.0.1:8080/nginx_status.
#
# Wiring caveat 2 (logs): Vector reads /var/log/openresty/access.json and
# /var/log/openresty/modsecurity-audit.json from the shared edge_logs volume.
# ModSecurity audit events are written there by default, but the signed access
# log is currently emitted to <EDGE_DATA_DIR>/logs/access.log, so access.json
# stays empty until the release config points access_log at
# /var/log/openresty/access.json.
